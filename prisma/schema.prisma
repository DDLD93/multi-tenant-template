generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum ActorType {
  PLATFORM_USER
  TENANT_USER
  CLIENT
  SYSTEM
}

enum SessionUserType {
  PLATFORM
  TENANT
  CLIENT
}

enum SessionScope {
  FULL
  MUST_CHANGE_PASSWORD
}

enum OtpPurpose {
  CLIENT_LOGIN
  CLIENT_SIGNUP
  TENANT_REGISTRATION
  TENANT_OWNER_CHANGE_EMAIL
}

model Tenant {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  status        TenantStatus  @default(ACTIVE)
  ownerUserId   String?
  companyEmail  String?
  companyPhone  String?
  website       String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  region        String?
  postalCode    String?
  country       String?
  settingsJson  Json          @default("{}")
  createdAt     DateTime      @default(now())
  archivedAt    DateTime?

  users         TenantUser[]
  clients       Client[]
  pendingClientRegistrations PendingClientRegistration[]
  roleTemplates RoleTemplate[]
  templates     Template[]
  activityLogs  ActivityLog[]

  @@index([status])
}

model PlatformUser {
  id                   String      @id @default(cuid())
  email                String      @unique
  passwordHash         String
  mustChangePassword   Boolean     @default(true)
  status               UserStatus  @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  isSuperAdmin         Boolean     @default(false)
  permissions          String[]    @default([])
  createdAt            DateTime    @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int         @default(0)
  lockedUntil          DateTime?
}

model TenantUser {
  id                   String      @id @default(cuid())
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                String
  passwordHash         String
  mustChangePassword   Boolean     @default(true)
  status               UserStatus  @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  isOwner              Boolean     @default(false)
  permissions          String[]    @default([])
  createdAt            DateTime    @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int         @default(0)
  lockedUntil          DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Client {
  id                   String       @id @default(cuid())
  tenantId             String
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                String
  passwordHash         String?
  mustChangePassword   Boolean      @default(false)
  status               ClientStatus @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  profileJson          Json         @default("{}")
  createdAt            DateTime     @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int          @default(0)
  lockedUntil          DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model PasswordResetToken {
  id         String           @id @default(cuid())
  tokenHash  String           @unique
  userType   SessionUserType
  userId     String
  tenantId   String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([expiresAt])
}

/// In-flight client self-signup: created after form+password, deleted after OTP verifies.
model PendingClientRegistration {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  firstName    String?
  lastName     String?
  otherName    String?
  phone        String?
  profileJson  Json     @default("{}")
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RoleTemplate {
  id          String     @id @default(cuid())
  scope       RoleScope
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  permissions String[]
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())

  @@unique([scope, tenantId, name])
  @@index([scope, tenantId])
}

model Permission {
  key         String  @id
  module      String
  description String
}

model ActivityLog {
  id         String     @id @default(cuid())
  tenantId   String?
  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorType  ActorType
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  beforeJson Json?
  afterJson  Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId])
  @@index([action])
}

model OtpRequest {
  id         String     @id @default(cuid())
  identifier String
  codeHash   String
  purpose    OtpPurpose
  tenantId   String?
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([identifier, createdAt])
  @@index([tenantId])
}

model Session {
  id          String           @id
  userId      String
  userType    SessionUserType
  tenantId    String?
  scope       SessionScope     @default(FULL)
  issuedAt    DateTime         @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  ip          String?
  userAgent   String?

  @@index([userId])
  @@index([expiresAt])
}

model Template {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String
  name        String
  contentJson Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([tenantId, type])
}

model PasswordHistory {
  id        String   @id @default(cuid())
  userType  SessionUserType
  userId    String
  hash      String
  createdAt DateTime @default(now())

  @@index([userType, userId, createdAt])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String
  scope      String
  success    Boolean
  ip         String?
  createdAt  DateTime @default(now())

  @@index([identifier, scope, createdAt])
}

model ReservedSlug {
  slug      String   @id
  reason    String
  createdAt DateTime @default(now())
}
